# =====================================================================
#  Study Sphere AI  -  environment variables
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit the real .env file (it is git-ignored).
# =====================================================================

# --- Groq AI (required for all AI features) -------------------------
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the default model.
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Telegram bot (required only if you run the bot) ----------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional but recommended: a secret to verify webhook calls.
# WEBHOOK_SECRET=some_long_random_string

# --- Web app security (set a strong, stable secret in production) ----
# If unset, a random secret is generated per process (tokens won't
# survive restarts). Set this in production.
JWT_SECRET=change_me_to_a_long_random_secret
# Token lifetime in seconds (default 7 days).
# JWT_TTL_SECONDS=604800

# --- CORS (REQUIRED in production) ----------------------------------
# Comma-separated list of frontend origins allowed to call this API.
# The frontend is on Vercel, the backend on Render/Railway (different
# origins), so this MUST include your Vercel URL.
# *.vercel.app preview URLs and localhost are always allowed automatically.
ALLOWED_ORIGINS=https://your-app.vercel.app

# --- MongoDB Atlas (web-analytics dashboard only) -------------------
# Analytics is disabled gracefully if this is unset.
# MONGODB_URI_WEB=mongodb+srv://user:pass@cluster.mongodb.net/studysphere?retryWrites=true&w=majority

# --- Persistent database path (production) --------------------------
# Point this at a MOUNTED DISK so SQLite data survives restarts, e.g.
# Render disk at /data or Railway volume at /data.
# DB_PATH=/data/study_sphere.db

# --- Optional tuning -------------------------------------------------
# WEB_CONCURRENCY=2          # gunicorn workers
# FAIL_FAST=1                # abort startup if required vars are missing
# TELEGRAM_ADMIN_ID=123456   # admin id for /api/analytics/dashboard-stats
# RATE_LIMIT=120
# RATE_WINDOW=60
