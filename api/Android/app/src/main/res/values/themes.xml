<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Launch theme using the AndroidX Splash Screen API.
      Shows the official AI Notebook logo on a branded space background,
      then hands off to the Compose UI. No generated/alternative branding.
    -->
    <style name="Theme.AiNotebook.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/space_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/space_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.AiNotebook</item>
        <item name="android:statusBarColor">@color/space_bg</item>
        <item name="android:windowBackground">@color/space_bg</item>
    </style>

    <!-- Main app theme. Compose drives all the actual colours/Material3. -->
    <style name="Theme.AiNotebook" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/space_bg</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

</resources>
